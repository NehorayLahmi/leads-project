// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Pro {
  id           String     @id @default(uuid())
  name         String
  phone        String
  city         String
  isActive     Boolean    @default(true)
  pricePerLead Int
  calls        Call[]
  formLeads    FormLead[]
}

model Call {
  id               String  @id @default(uuid())
  callerPhone      String
  destinationPhone String
  duration         Int
  status           String
  recordingUrl     String?
  proId            String
  pro              Pro     @relation(fields: [proId], references: [id])
}

model FormLead {
  id          String  @id @default(uuid())
  clientName  String
  clientPhone String
  issueType   String
  isSentToPro Boolean @default(false)
  proId       String
  pro         Pro     @relation(fields: [proId], references: [id])
}
